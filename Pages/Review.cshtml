@page
@model Boggle.Pages.ReviewModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Review Saved Words";
}

<div class="text-center">
    <h1 class="display-4">Review Saved Words</h1>
    <br />

    <a href="#" id="backToGame">Back to Game</a>

    <div class="review-container" id="PlayerResults">
        <h3>Saved Grid</h3>
        @* Grid editor and display *@


        @if (Model.GridRows == null || Model.GridRows.Count == 0)
        {
            <p><em>No grid saved.</em></p>
        }
        else
        {
            <table id="boggleGrid" class="table table-bordered">
                <tbody>
                    @for (int r = 0; r < Model.GridRows.Count; r++)
                    {
                        <tr>
                            @for (int c = 0; c < Model.GridRows[r].Length; c++)
                            {
                                <td id="r@(r+1)c@(c+1)">@Model.GridRows[r][c]</td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        }

        <h3>Saved Words</h3>
        @if (Model.SavedWords == null || Model.SavedWords.Count == 0)
        {
            <p>No saved words yet.</p>
        }
        else
        {
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Player</th>
                        <th>Words</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var kv in Model.SavedWords)
                    {
                        var playerNumber = kv.Key + 1;
                        <tr>
                            <td>Player @playerNumber</td>
                            <td>
                                @if (kv.Value == null || kv.Value.Length == 0)
                                {
                                    <em>(no words)</em>
                                }
                                else
                                {
                                    <ul id="playerWords@(kv.Key)">
                                        @foreach (var res in Model.PlayerResults[kv.Key])
                                        {
                                            var classes = new List<string>();
                                            if (res.IsValid) classes.Add("valid"); else classes.Add("invalid");
                                            if (res.IsDuplicate) classes.Add("duplicate");
                                            var liClass = string.Join(" ", classes);
                                            // encode path as semicolon-separated r,c pairs
                                            var pathAttr = res.Path != null ? string.Join(";", res.Path.Select(p=>$"{p.r},{p.c}")) : string.Empty;
                                            var defAttr = res.Definition ?? string.Empty;
                                            <li class="@liClass" data-path="@pathAttr" data-definition="@defAttr" title="@defAttr">@res.Word @if(res.IsDuplicate){<span class="dupnote">(duplicate)</span>}</li>
                                        }
                                    </ul>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

<script>
    const antiforgeryToken = '@Antiforgery.GetAndStoreTokens(HttpContext).RequestToken';

    async function getDefinition(word) {
        const response = await $.get(`https://api.dictionaryapi.dev/api/v2/entries/en/${word}`);
        return response;
    }

    function clearHighlights() {
        $('#boggleGrid td.highlight').removeClass('highlight');
        $('#boggleGrid td').css('background', '');
    }

    function bindWordHover() {
        $('ul[id^="playerWords"] li').off('mouseenter mouseleave');
        $('ul[id^="playerWords"] li').on('mouseenter', function() {
            clearHighlights();
            const path = $(this).attr('data-path');
            if (!path) return;
            const pairs = path.split(';').filter(x=>x.length>0);
            pairs.forEach(p => {
                const [r,c] = p.split(',').map(Number);
                const id = `r${r+1}c${c+1}`;
                const $cell = $(`#${id}`);
                if ($cell.length > 0) {
                    $cell.addClass('highlight');
                    $cell.css('background', '#ffff99');
                }
            });
        });

        $('ul[id^="playerWords"] li').on('mouseleave', () => { clearHighlights(); });

        $('li.valid, li.invalid').on('mouseenter', function() {
            clearHighlights();
            const path = $(this).attr('data-path');
            if (!path) return;
            const pairs = path.split(';').filter(x=>x.length>0);
            pairs.forEach(p => {
                const [r,c] = p.split(',').map(Number);
                const id = `r${r+1}c${c+1}`;
                const $cell = $(`#${id}`);
                if ($cell.length > 0) {
                    $cell.addClass('highlight');
                }
            });
        });

        $('li.valid, li.invalid').on('mouseleave', () => { clearHighlights(); });
    }

    // Document ready
    $(function() {
        // Bind back link: clean empty words then navigate back to Index
        $('#backToGame').on('click', async (e) => {
            e.preventDefault();
            // Immediately clear displayed saved words for instant feedback
            $('ul[id^="playerWords"]').empty();

            // Clear client-side localStorage for failed saves/grids
            try {
                localStorage.removeItem('boggle_failed_saves');
                localStorage.removeItem('boggle_failed_grids');
            } catch (err) {
                console.error('localStorage clear error', err);
            }
            // Clear server-side SavedWords
            try {
                await $.ajax({
                    url: '?handler=CleanWords',
                    method: 'POST',
                    contentType: 'application/json',
                    headers: {
                        'RequestVerificationToken': antiforgeryToken
                    },
                    data: '{}'
                });
            } catch (err) {
                console.error('CleanWords error', err);
            }
            window.location.href = '/Index';
        });

        // initial bind
        bindWordHover();
    });
</script>
