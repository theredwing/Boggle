@page
@model IndexModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Home page";
}

<div class="text-center">
    <h1 class="display-4">Boggle</h1>
    <br />
    <div id="notifications" style="margin-bottom:10px; text-align:left; display:inline-block;"></div>
    @{ 
        var rows = 5;
        var cols = 5;
    }

    <button id="shuffleBtn" type="button">Shuffle</button>
    <a id="reviewLink" class="btn btn-link" href="/Review" style="margin-left:10px">Review</a>

    <div id="playersSection" style="margin-top:15px; text-align:left; display:inline-block;">
        <label for="playerCount">Players:</label>
        <select id="playerCount">
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3">3</option>
            <option value="4">4</option>
        </select>

        <div id="playersContainer" style="margin-top:10px;"></div>
    </div>

    <table id="boggleTable">
        @for (int r = 1; r <= rows; r++)
        {
            <tr>
                @for (int c = 1; c <= cols; c++)
                {
                    <td class="my-box" id="@($"r{r}c{c}")">&nbsp;</td>
                }
            </tr>
        }
    </table>

    <script>
        const rows = @rows;
        const cols = @cols;
        const antiforgeryToken = '@Antiforgery.GetAndStoreTokens(HttpContext).RequestToken';

        // Player words storage (hidden lists after each player's turn)
        const playerHiddenWords = [[], [], [], []];

        function randomLetter() {
            return String.fromCharCode('A'.charCodeAt(0) + Math.floor(Math.random() * 26));
        }

        function shuffleGrid() {
            const forbidden = new Set(['J','K','Q','X','Z']);
            for (let r = 1; r <= rows; r++) {
                for (let c = 1; c <= cols; c++) {
                    const id = `r${r}c${c}`;
                    const el = document.getElementById(id);
                    if (!el) continue;

                    let letter;
                    let attempts = 0;
                    do {
                        letter = randomLetter();
                        attempts++;
                    } while (attempts < 2 && forbidden.has(letter));

                    el.textContent = letter;
                }
            }
        }

        // Players UI
        const playerCountSelect = document.getElementById('playerCount');
        const playersContainer = document.getElementById('playersContainer');
        const shuffleBtn = document.getElementById('shuffleBtn');

        function renderPlayers(count) {
            // clear stored hidden words when player count changes
            for (let i = 0; i < playerHiddenWords.length; i++) playerHiddenWords[i] = [];

            playersContainer.innerHTML = '';
            for (let i = 0; i < count; i++) {
                const panel = document.createElement('div');
                panel.style.marginBottom = '12px';
                panel.id = `playerPanel${i}`;
                panel.innerHTML = `
                    <strong>Player ${i+1}</strong>
                    <button type="button" id="startBtn${i}">Start</button>
                    <span id="timer${i}" style="margin-left:10px">Time: 0s</span>
                    <div id="inputArea${i}" style="margin-top:6px; display:none;">
                        <textarea id="playerTextarea${i}" rows="3" cols="30" placeholder="Enter words separated by commas"></textarea>
                    </div>
                    <ul id="hiddenList${i}" style="display:none"></ul>
                `;
                playersContainer.appendChild(panel);

                // attach start handler
                document.getElementById(`startBtn${i}`).addEventListener('click', () => handleStart(i));
            }

            // After render, shuffle must be pressed to enable first start
            disableAllStarts();
        }

        function disableAllStarts() {
            const count = parseInt(playerCountSelect.value);
            for (let i = 0; i < count; i++) {
                const btn = document.getElementById(`startBtn${i}`);
                if (btn) btn.disabled = true;
                const ta = document.getElementById(`playerTextarea${i}`);
                if (ta) ta.disabled = true;
                const inputArea = document.getElementById(`inputArea${i}`);
                if (inputArea) inputArea.style.display = 'none';
                const timerEl = document.getElementById(`timer${i}`);
                if (timerEl) timerEl.textContent = 'Time: 0s';
            }
        }

        function enableStart(index) {
            const btn = document.getElementById(`startBtn${index}`);
            if (btn) btn.disabled = false;
        }

        function handleStart(index) {
            const startBtn = document.getElementById(`startBtn${index}`);
            if (!startBtn) return;
            startBtn.disabled = true; // immediately disabled
            // show and enable textarea
            const inputArea = document.getElementById(`inputArea${index}`);
            const ta = document.getElementById(`playerTextarea${index}`);
            if (inputArea) inputArea.style.display = 'block';
            if (ta) { ta.disabled = false; ta.focus(); }

            // start 60s timer
            runTimerForPlayer(index, 60).then(() => finishPlayerTurn(index));
        }

        function runTimerForPlayer(playerIndex, seconds) {
            return new Promise(resolve => {
                const timerEl = document.getElementById(`timer${playerIndex}`);
                let remaining = seconds;
                if (timerEl) timerEl.textContent = `Time: ${remaining}s`;
                const iv = setInterval(() => {
                    remaining--;
                    if (timerEl) timerEl.textContent = `Time: ${remaining}s`;
                    if (remaining <= 0) {
                        clearInterval(iv);
                        if (timerEl) timerEl.textContent = 'Time: 0s';
                        resolve();
                    }
                }, 1000);
            });
        }

        async function savePlayerWords(index, words) {
            try {
                const resp = await fetch('?handler=SaveWords', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': antiforgeryToken
                    },
                    body: JSON.stringify({ playerIndex: index, words: words })
                });

                if (!resp.ok) {
                    console.error('SaveWords http error', resp.status);
                    return { success: false, error: `http ${resp.status}` };
                }

                const j = await resp.json();
                if (!j || !j.success) {
                    console.error('SaveWords response failure', j);
                    return { success: false, error: j && j.error ? j.error : 'unknown' };
                }

                return { success: true };
            }
            catch (err) {
                console.error('SaveWords exception', err);
                return { success: false, error: err && err.message ? err.message : String(err) };
            }
        }

        // Retry/backoff and offline persistence settings
        const MAX_SAVE_RETRIES = 5;
        const BASE_BACKOFF_MS = 1000; // 1s
        const MAX_BACKOFF_MS = 30000; // 30s
        const FAILED_SAVES_KEY = 'boggle_failed_saves';
        const FAILED_GRIDS_KEY = 'boggle_failed_grids';

        function getFailedSaves() {
            try {
                const raw = localStorage.getItem(FAILED_SAVES_KEY);
                return raw ? JSON.parse(raw) : [];
            } catch (e) {
                console.error('Failed to read failed saves', e);
                return [];
            }
        }

        function setFailedSaves(list) {
            try {
                localStorage.setItem(FAILED_SAVES_KEY, JSON.stringify(list));
                renderFailedNotifications();
            } catch (e) {
                console.error('Failed to persist failed saves', e);
            }
        }

        function addFailedSave(record) {
            const list = getFailedSaves();
            list.push(record);
            setFailedSaves(list);
        }

        function removeFailedSaveById(id) {
            const list = getFailedSaves().filter(x => x.id !== id);
            setFailedSaves(list);
        }

        function renderFailedNotifications() {
            const container = document.getElementById('notifications');
            if (!container) return;
            const list = getFailedSaves();
            container.innerHTML = '';
            if (!list || list.length === 0) return;
            const badge = document.createElement('div');
            badge.style.padding = '6px';
            badge.style.border = '1px solid #d9534f';
            badge.style.background = '#f2dede';
            badge.style.color = '#a94442';
            badge.textContent = `There are ${list.length} unsaved turn(s). `;
            const retryAll = document.createElement('button');
            retryAll.type = 'button';
            retryAll.textContent = 'Retry All Failed';
            retryAll.style.marginLeft = '8px';
            retryAll.addEventListener('click', () => tryResendFailedSaves());
            const clearAll = document.createElement('button');
            clearAll.type = 'button';
            clearAll.textContent = 'Clear All';
            clearAll.style.marginLeft = '8px';
            clearAll.addEventListener('click', () => { setFailedSaves([]); });
            badge.appendChild(retryAll);
            badge.appendChild(clearAll);
            container.appendChild(badge);
        }

        async function tryResendFailedSaves() {
            const list = getFailedSaves();
            if (!list || list.length === 0) return;
            // process sequentially to avoid spamming
            for (const rec of list.slice()) {
                try {
                    const res = await savePlayerWords(rec.playerIndex, rec.words);
                    if (res.success) {
                        removeFailedSaveById(rec.id);
                    }
                } catch (e) {
                    console.error('Resend failed for', rec, e);
                }
            }
            renderFailedNotifications();
        }

        // Failed grids storage helpers
        function getFailedGrids() {
            try {
                const raw = localStorage.getItem(FAILED_GRIDS_KEY);
                return raw ? JSON.parse(raw) : [];
            } catch (e) {
                console.error('Failed to read failed grids', e);
                return [];
            }
        }

        function setFailedGrids(list) {
            try {
                localStorage.setItem(FAILED_GRIDS_KEY, JSON.stringify(list));
                renderFailedNotifications();
            } catch (e) {
                console.error('Failed to persist failed grids', e);
            }
        }

        function addFailedGrid(record) {
            const list = getFailedGrids();
            list.push(record);
            setFailedGrids(list);
        }

        function removeFailedGridById(id) {
            const list = getFailedGrids().filter(x => x.id !== id);
            setFailedGrids(list);
        }

        async function tryResendFailedGrids() {
            const list = getFailedGrids();
            if (!list || list.length === 0) return;
            for (const rec of list.slice()) {
                try {
                    const resp = await fetch('?handler=SaveGrid', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': antiforgeryToken
                        },
                        body: JSON.stringify({ grid: rec.grid })
                    });
                    if (resp.ok) {
                        const j = await resp.json();
                        if (j && j.success) removeFailedGridById(rec.id);
                    }
                } catch (e) {
                    console.error('Resend grid failed for', rec, e);
                }
            }
            renderFailedNotifications();
        }


        async function finishPlayerTurn(index) {
            // read textarea, parse comma-separated words, store in hidden list
            const ta = document.getElementById(`playerTextarea${index}`);
            const hiddenUl = document.getElementById(`hiddenList${index}`);
            let words = [];
            // panel reference needed for notes/rejected lists
            const panel = document.getElementById(`playerPanel${index}`);
            if (ta) {
                const raw = ta.value || '';
                const all = raw.split(',').map(s => s.trim()).filter(s => s.length > 0);
                // enforce minimum length 4
                const minLen = 4;
                const valid = all.filter(w => w.length >= minLen);
                const rejected = all.filter(w => w.length < minLen);
                words = valid;
                ta.value = '';
                // show rejected note if any
                const existingNote = document.getElementById(`rejectedMsg${index}`);
                if (existingNote && existingNote.parentNode) existingNote.parentNode.removeChild(existingNote);
                if (rejected.length > 0) {
                    const note = document.createElement('span');
                    note.id = `rejectedMsg${index}`;
                    note.style.marginLeft = '8px';
                    note.style.color = '#a94442';
                    note.textContent = `${rejected.length} word(s) discarded (must be ${minLen}+ chars)`;
                    if (panel) panel.appendChild(note);
                }
                // hide input area
                const inputArea = document.getElementById(`inputArea${index}`);
                if (inputArea) inputArea.style.display = 'none';
                ta.disabled = true;
            }

            playerHiddenWords[index] = words;
            if (hiddenUl) {
                hiddenUl.innerHTML = '';
                // valid words (kept hidden for review)
                words.forEach(w => {
                    const li = document.createElement('li');
                    li.textContent = w;
                    hiddenUl.appendChild(li);
                });
                hiddenUl.style.display = 'none'; // keep hidden

                // show rejected words (those shorter than min length) visibly in gray
                const existingRejected = document.getElementById(`rejectedList${index}`);
                if (existingRejected && existingRejected.parentNode) existingRejected.parentNode.removeChild(existingRejected);
                if (typeof rejected !== 'undefined' && rejected.length > 0) {
                    const rejUl = document.createElement('ul');
                    rejUl.id = `rejectedList${index}`;
                    rejUl.style.color = '#777';
                    rejUl.style.marginTop = '6px';
                    rejected.forEach(w => {
                        const li = document.createElement('li');
                        li.textContent = w + ' (rejected - too short)';
                        li.style.color = '#777';
                        rejUl.appendChild(li);
                    });
                    if (panel) panel.appendChild(rejUl);
                }
            }

            // mark player as done (immediate feedback)
            if (panel) {
                const doneLabel = document.createElement('span');
                doneLabel.textContent = ' Done';
                panel.appendChild(doneLabel);
            }

            // show saving indicator
            let savingEl = document.createElement('span');
            savingEl.textContent = ' Saving...';
            if (panel) panel.appendChild(savingEl);

            // attempt to save with retries, exponential backoff, and offline persistence
            function arraysEqual(a, b) {
                if (!Array.isArray(a) || !Array.isArray(b)) return false;
                if (a.length !== b.length) return false;
                for (let i = 0; i < a.length; i++) if (a[i] !== b[i]) return false;
                return true;
            }

            async function attemptSaveWithRetries() {
                for (let attempt = 1; attempt <= MAX_SAVE_RETRIES; attempt++) {
                    // update saving indicator
                    if (savingEl) savingEl.textContent = ` Saving... (attempt ${attempt}/${MAX_SAVE_RETRIES})`;
                    const result = await savePlayerWords(index, words);
                    if (result.success) {
                        // remove saving and retry UI if present
                        if (savingEl && savingEl.parentNode) savingEl.parentNode.removeChild(savingEl);
                        const retryBtn = document.getElementById(`retryBtn${index}`);
                        if (retryBtn && retryBtn.parentNode) retryBtn.parentNode.removeChild(retryBtn);

                        // remove any persisted failed saves matching this player's words
                        const persisted = getFailedSaves();
                        const remaining = persisted.filter(rec => !(rec.playerIndex === index && arraysEqual(rec.words, words)));
                        setFailedSaves(remaining);

                        // enable next player's start or re-enable shuffle if last
                        const count = parseInt(playerCountSelect.value);
                        const next = index + 1;
                        if (next < count) {
                            enableStart(next);
                        } else {
                            // finished all players
                            shuffleBtn.disabled = false;
                        }
                        return { success: true };
                    }

                    // failed - wait exponential backoff before next attempt
                    const delay = Math.min(BASE_BACKOFF_MS * Math.pow(2, attempt - 1), MAX_BACKOFF_MS);
                    await new Promise(r => setTimeout(r, delay));
                }

                // All attempts failed - persist to localStorage for offline recovery
                const failRecord = {
                    id: `${Date.now()}-${Math.random().toString(36).slice(2)}`,
                    playerIndex: index,
                    words: words,
                    error: 'max retries exceeded',
                    ts: Date.now()
                };
                addFailedSave(failRecord);

                // remove saving indicator and show retry button
                if (savingEl && savingEl.parentNode) savingEl.parentNode.removeChild(savingEl);
                let retryBtn = document.getElementById(`retryBtn${index}`);
                if (!retryBtn) {
                    retryBtn = document.createElement('button');
                    retryBtn.id = `retryBtn${index}`;
                    retryBtn.type = 'button';
                    retryBtn.textContent = 'Retry Save';
                    retryBtn.style.marginLeft = '8px';
                    retryBtn.addEventListener('click', async () => {
                        retryBtn.disabled = true;
                        if (panel) panel.appendChild(savingEl);
                        // try resending from storage for this record
                        await tryResendFailedSaves();
                        retryBtn.disabled = false;
                    });
                    if (panel) panel.appendChild(retryBtn);
                } else {
                    retryBtn.disabled = false;
                }

                // update global notification UI
                renderFailedNotifications();
                console.error('Save failed for player after retries, persisted for later', index);
                return { success: false };
            }

            await attemptSaveWithRetries();
        }

        // helper to save grid
        async function saveGrid(gridArray) {
            try {
                const resp = await fetch('?handler=SaveGrid', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': antiforgeryToken
                    },
                    body: JSON.stringify({ grid: gridArray })
                });
                if (!resp.ok) return { success: false, error: `http ${resp.status}` };
                const j = await resp.json();
                if (!j || !j.success) return { success: false, error: j && j.error ? j.error : 'unknown' };
                return { success: true };
            } catch (e) {
                return { success: false, error: e && e.message ? e.message : String(e) };
            }
        }

        // Shuffle button behavior: populate grid, save it, and enable player1 start
        shuffleBtn.addEventListener('click', async () => {
            shuffleGrid();

            // build grid array (flattened row-major)
            const grid = [];
            for (let r = 1; r <= rows; r++) {
                for (let c = 1; c <= cols; c++) {
                    const id = `r${r}c${c}`;
                    const el = document.getElementById(id);
                    grid.push(el && el.textContent ? el.textContent.trim() : '');
                }
            }

            // try to save grid with retries; if final failure, persist locally but allow play to continue
            let gridSaved = false;
            for (let attempt = 1; attempt <= MAX_SAVE_RETRIES; attempt++) {
                const res = await saveGrid(grid);
                if (res.success) { gridSaved = true; break; }
                const delay = Math.min(BASE_BACKOFF_MS * Math.pow(2, attempt - 1), MAX_BACKOFF_MS);
                await new Promise(r => setTimeout(r, delay));
            }
            if (!gridSaved) {
                const rec = { id: `${Date.now()}-${Math.random().toString(36).slice(2)}`, grid: grid, error: 'max retries exceeded', ts: Date.now() };
                addFailedGrid(rec);
            }

            // reset hidden words
            for (let i = 0; i < playerHiddenWords.length; i++) playerHiddenWords[i] = [];
            // reset displays
            renderPlayers(parseInt(playerCountSelect.value));
            // enable first player's start
            enableStart(0);
            shuffleBtn.disabled = true;
        });

        // init
        playerCountSelect.addEventListener('change', () => renderPlayers(parseInt(playerCountSelect.value)));
        renderPlayers(parseInt(playerCountSelect.value));
        // attempt to resend failed saves and grids on load and when network returns
        tryResendFailedSaves();
        tryResendFailedGrids();
        window.addEventListener('online', () => { tryResendFailedSaves(); tryResendFailedGrids(); });
    </script>
</div>
