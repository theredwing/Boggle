@page
@model IndexModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Home page";
}

<div class="text-center">
    <h1 class="display-4">Boggle</h1>
    <br />
    <div id="notifications"></div>
    @{ 
        var rows = 5;
        var cols = 5;
    }

    <button id="shuffleBtn" type="button">Shuffle</button>
    <a id="reviewLink" class="btn btn-link" href="/Review">Review</a>
    <a id="instructionsLink" class="btn btn-link" href="#">Instructions</a>

    <div id="playersSection">
        <label for="playerCount">Players:</label>
        <select id="playerCount">
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3">3</option>
            <option value="4">4</option>
        </select>

        <div id="playersContainer"></div>
    </div>

    <table id="boggleTable">
        @for (int r = 1; r <= rows; r++)
        {
            <tr>
                @for (int c = 1; c <= cols; c++)
                {
                    <td class="my-box" id="@($"r{r}c{c}")">&nbsp;</td>
                }
            </tr>
        }
    </table>

    <!-- Instructions Modal -->
    <div id="instructionsModal" class="modal">
        <div class="modal-content">
            <span class="close">&times;</span>
            <h2>How to Play Boggle</h2>
            <ol class="instructions-list">
                <li>Select the number of players</li>
                <li>Press "Shuffle" to generate a new letter grid</li>
                <li>The lowest numbered player clicks "Start", enters words separated by commas, until time expires</li>
                <li>The next lowest numbered player repeats step 3, and so on</li>
            </ol>
        </div>
    </div>

    <script>
        const rows = @rows;
        const cols = @cols;
        const antiforgeryToken = '@Antiforgery.GetAndStoreTokens(HttpContext).RequestToken';

        // Player words storage (hidden lists after each player's turn)
        const playerHiddenWords = [[], [], [], []];

        // Track completed players
        let completedPlayers = 0;
        let totalPlayers = 0;

        // jQuery elements (will be initialized on document ready)
        let $playerCountSelect, $playersContainer, $shuffleBtn, $reviewLink;

        function randomLetter() {
            return String.fromCharCode('A'.charCodeAt(0) + Math.floor(Math.random() * 26));
        }

        function shuffleGrid() {
            const forbidden = new Set(['J','K','Q','X','Z']);
            const vowels = new Set(['A','E','I','O','U','Y']);

            for (let r = 1; r <= rows; r++) {
                for (let c = 1; c <= cols; c++) {
                    const id = `r${r}c${c}`;
                    const $el = $(`#${id}`);
                    if ($el.length === 0) continue;

                    let letter;
                    let attempts = 0;

                    // First pass: try to avoid forbidden letters (max 2 attempts)
                    do {
                        letter = randomLetter();
                        attempts++;
                    } while (attempts < 2 && forbidden.has(letter));

                    // Second pass: if consonant (not Y), try one more time for vowel
                    if (!vowels.has(letter)) {
                        const tryVowel = randomLetter();
                        if (vowels.has(tryVowel)) {
                            letter = tryVowel;
                        }
                    }

                    $el.text(letter);
                }
            }
        }

        function renderPlayers(count) {
            // clear stored hidden words when player count changes
            for (let i = 0; i < playerHiddenWords.length; i++) playerHiddenWords[i] = [];

            // Reset completed players counter
            completedPlayers = 0;
            totalPlayers = count;

            $playersContainer.empty();
            for (let i = 0; i < count; i++) {
                const $panel = $('<div></div>')
                    .addClass('player-panel')
                    .attr('id', `playerPanel${i}`)
                    .html(`
                        <strong>Player ${i+1}</strong>
                        <button type="button" id="startBtn${i}">Start</button>
                        <span id="timer${i}" class="player-timer">Time: 0s</span>
                        <div id="inputArea${i}" class="player-input-area">
                            <textarea id="playerTextarea${i}" rows="3" cols="30" placeholder="Enter words separated by commas"></textarea>
                        </div>
                        <ul id="hiddenList${i}" class="player-hidden-list"></ul>
                    `);
                $playersContainer.append($panel);

                // attach start handler
                $(`#startBtn${i}`).on('click', () => handleStart(i));
            }

            // After render, shuffle must be pressed to enable first start
            disableAllStarts();
        }

        function updateReviewLinkState() {
            if (completedPlayers === totalPlayers && totalPlayers > 0) {
                $reviewLink.removeClass('disabled');
            } else {
                $reviewLink.addClass('disabled');
            }
        }

        function disableAllStarts() {
            const count = parseInt($playerCountSelect.val());
            for (let i = 0; i < count; i++) {
                $(`#startBtn${i}`).prop('disabled', true);
                $(`#playerTextarea${i}`).prop('disabled', true);
                $(`#inputArea${i}`).hide();
                $(`#timer${i}`).text('Time: 0s');
            }
        }

        function enableStart(index) {
            $(`#startBtn${index}`).prop('disabled', false);
        }

        function handleStart(index) {
            const $startBtn = $(`#startBtn${index}`);
            if ($startBtn.length === 0) return;
            $startBtn.prop('disabled', true); // immediately disabled
            // show and enable textarea
            const $inputArea = $(`#inputArea${index}`);
            const $ta = $(`#playerTextarea${index}`);
            $inputArea.show();
            $ta.prop('disabled', false).focus();

            // start 180s timer (3 minutes)
            runTimerForPlayer(index, 180).then(() => finishPlayerTurn(index));
        }

        function runTimerForPlayer(playerIndex, seconds) {
            return new Promise(resolve => {
                const $timerEl = $(`#timer${playerIndex}`);
                let remaining = seconds;
                $timerEl.text(`Time: ${remaining}s`);
                const iv = setInterval(() => {
                    remaining--;
                    $timerEl.text(`Time: ${remaining}s`);
                    if (remaining <= 0) {
                        clearInterval(iv);
                        $timerEl.text('Time: 0s');
                        resolve();
                    }
                }, 1000);
            });
        }

        async function savePlayerWords(index, words) {
            try {
                const resp = await $.ajax({
                    url: '?handler=SaveWords',
                    method: 'POST',
                    contentType: 'application/json',
                    headers: {
                        'RequestVerificationToken': antiforgeryToken
                    },
                    data: JSON.stringify({ playerIndex: index, words: words })
                });

                if (!resp || !resp.success) {
                    console.error('SaveWords response failure', resp);
                    return { success: false, error: resp && resp.error ? resp.error : 'unknown' };
                }

                return { success: true };
            }
            catch (err) {
                console.error('SaveWords exception', err);
                return { success: false, error: err && err.message ? err.message : String(err) };
            }
        }

        // Retry/backoff and offline persistence settings
        const MAX_SAVE_RETRIES = 5;
        const BASE_BACKOFF_MS = 1000; // 1s
        const MAX_BACKOFF_MS = 30000; // 30s
        const FAILED_SAVES_KEY = 'boggle_failed_saves';
        const FAILED_GRIDS_KEY = 'boggle_failed_grids';

        function getFailedSaves() {
            try {
                const raw = localStorage.getItem(FAILED_SAVES_KEY);
                return raw ? JSON.parse(raw) : [];
            } catch (e) {
                console.error('Failed to read failed saves', e);
                return [];
            }
        }

        function setFailedSaves(list) {
            try {
                localStorage.setItem(FAILED_SAVES_KEY, JSON.stringify(list));
                renderFailedNotifications();
            } catch (e) {
                console.error('Failed to persist failed saves', e);
            }
        }

        function addFailedSave(record) {
            const list = getFailedSaves();
            list.push(record);
            setFailedSaves(list);
        }

        function removeFailedSaveById(id) {
            const list = getFailedSaves().filter(x => x.id !== id);
            setFailedSaves(list);
        }

        function renderFailedNotifications() {
            const $container = $('#notifications');
            if ($container.length === 0) return;
            const list = getFailedSaves();
            $container.empty();
            if (!list || list.length === 0) return;
            const $badge = $('<div></div>')
                .addClass('notification-badge')
                .text(`There are ${list.length} unsaved turn(s). `);
            const $retryAll = $('<button></button>')
                .attr('type', 'button')
                .text('Retry All Failed')
                .on('click', () => tryResendFailedSaves());
            const $clearAll = $('<button></button>')
                .attr('type', 'button')
                .text('Clear All')
                .on('click', () => { setFailedSaves([]); });
            $badge.append($retryAll).append($clearAll);
            $container.append($badge);
        }

        async function tryResendFailedSaves() {
            const list = getFailedSaves();
            if (!list || list.length === 0) return;
            // process sequentially to avoid spamming
            for (const rec of list.slice()) {
                try {
                    const res = await savePlayerWords(rec.playerIndex, rec.words);
                    if (res.success) {
                        removeFailedSaveById(rec.id);
                    }
                } catch (e) {
                    console.error('Resend failed for', rec, e);
                }
            }
            renderFailedNotifications();
        }

        // Failed grids storage helpers
        function getFailedGrids() {
            try {
                const raw = localStorage.getItem(FAILED_GRIDS_KEY);
                return raw ? JSON.parse(raw) : [];
            } catch (e) {
                console.error('Failed to read failed grids', e);
                return [];
            }
        }

        function setFailedGrids(list) {
            try {
                localStorage.setItem(FAILED_GRIDS_KEY, JSON.stringify(list));
                renderFailedNotifications();
            } catch (e) {
                console.error('Failed to persist failed grids', e);
            }
        }

        function addFailedGrid(record) {
            const list = getFailedGrids();
            list.push(record);
            setFailedGrids(list);
        }

        function removeFailedGridById(id) {
            const list = getFailedGrids().filter(x => x.id !== id);
            setFailedGrids(list);
        }

        async function tryResendFailedGrids() {
            const list = getFailedGrids();
            if (!list || list.length === 0) return;
            for (const rec of list.slice()) {
                try {
                    const resp = await $.ajax({
                        url: '?handler=SaveGrid',
                        method: 'POST',
                        contentType: 'application/json',
                        headers: {
                            'RequestVerificationToken': antiforgeryToken
                        },
                        data: JSON.stringify({ grid: rec.grid })
                    });
                    if (resp && resp.success) removeFailedGridById(rec.id);
                } catch (e) {
                    console.error('Resend grid failed for', rec, e);
                }
            }
            renderFailedNotifications();
        }


        async function finishPlayerTurn(index) {
            // read textarea, parse comma-separated words, store in hidden list
            const $ta = $(`#playerTextarea${index}`);
            const $hiddenUl = $(`#hiddenList${index}`);
            let words = [];
            // panel reference needed for notes/rejected lists
            const $panel = $(`#playerPanel${index}`);
            if ($ta.length > 0) {
                const raw = $ta.val() || '';
                const all = raw.split(',').map(s => s.trim()).filter(s => s.length > 0);
                // enforce minimum length 4
                const minLen = 4;
                const valid = all.filter(w => w.length >= minLen);
                const rejected = all.filter(w => w.length < minLen);
                words = valid;
                $ta.val('');
                // show rejected note if any
                $(`#rejectedMsg${index}`).remove();
                if (rejected.length > 0) {
                    const $note = $('<span></span>')
                        .attr('id', `rejectedMsg${index}`)
                        .addClass('rejected-msg')
                        .text(`${rejected.length} word(s) discarded (must be ${minLen}+ chars)`);
                    $panel.append($note);
                }
                // hide input area
                $(`#inputArea${index}`).hide();
                $ta.prop('disabled', true);

                playerHiddenWords[index] = words;
                if ($hiddenUl.length > 0) {
                    $hiddenUl.empty();
                    // valid words (kept hidden for review)
                    words.forEach(w => {
                        $('<li></li>').text(w).appendTo($hiddenUl);
                    });
                    $hiddenUl.hide(); // keep hidden

                    // show rejected words (those shorter than min length) visibly in gray
                    $(`#rejectedList${index}`).remove();
                    if (rejected.length > 0) {
                        const $rejUl = $('<ul></ul>')
                            .attr('id', `rejectedList${index}`)
                            .addClass('rejected-list');
                        rejected.forEach(w => {
                            $('<li></li>').text(w + ' (rejected - too short)').appendTo($rejUl);
                        });
                        $panel.append($rejUl);
                    }
                }
            }

            // mark player as done (immediate feedback)
            if ($panel.length > 0) {
                $('<span></span>').text(' Done').appendTo($panel);
            }

            // show saving indicator
            let $savingEl = $('<span></span>').text(' Saving...');
            $panel.append($savingEl);

            // attempt to save with retries, exponential backoff, and offline persistence
            function arraysEqual(a, b) {
                if (!Array.isArray(a) || !Array.isArray(b)) return false;
                if (a.length !== b.length) return false;
                for (let i = 0; i < a.length; i++) if (a[i] !== b[i]) return false;
                return true;
            }

            async function attemptSaveWithRetries() {
                for (let attempt = 1; attempt <= MAX_SAVE_RETRIES; attempt++) {
                    // update saving indicator
                    if ($savingEl.length > 0) $savingEl.text(` Saving... (attempt ${attempt}/${MAX_SAVE_RETRIES})`);
                    const result = await savePlayerWords(index, words);
                    if (result.success) {
                        // remove saving and retry UI if present
                        $savingEl.remove();
                        $(`#retryBtn${index}`).remove();

                        // remove any persisted failed saves matching this player's words
                        const persisted = getFailedSaves();
                        const remaining = persisted.filter(rec => !(rec.playerIndex === index && arraysEqual(rec.words, words)));
                        setFailedSaves(remaining);

                        // Increment completed players count
                        completedPlayers++;
                        updateReviewLinkState();

                        // enable next player's start or re-enable shuffle if last
                        const count = parseInt($playerCountSelect.val());
                        const next = index + 1;
                        if (next < count) {
                            enableStart(next);
                        } else {
                            // finished all players
                            $shuffleBtn.prop('disabled', false);
                        }
                        return { success: true };
                    }

                    // failed - wait exponential backoff before next attempt
                    const delay = Math.min(BASE_BACKOFF_MS * Math.pow(2, attempt - 1), MAX_BACKOFF_MS);
                    await new Promise(r => setTimeout(r, delay));
                }

                // All attempts failed - persist to localStorage for offline recovery
                const failRecord = {
                    id: `${Date.now()}-${Math.random().toString(36).slice(2)}`,
                    playerIndex: index,
                    words: words,
                    error: 'max retries exceeded',
                    ts: Date.now()
                };
                addFailedSave(failRecord);

                // remove saving indicator and show retry button
                $savingEl.remove();
                let $retryBtn = $(`#retryBtn${index}`);
                if ($retryBtn.length === 0) {
                    $retryBtn = $('<button></button>')
                        .attr('id', `retryBtn${index}`)
                        .attr('type', 'button')
                        .text('Retry Save')
                        .css('margin-left', '8px')
                        .on('click', async function() {
                            $(this).prop('disabled', true);
                            $panel.append($savingEl);
                            // try resending from storage for this record
                            await tryResendFailedSaves();
                            $(this).prop('disabled', false);
                        });
                    $panel.append($retryBtn);
                } else {
                    $retryBtn.prop('disabled', false);
                }

                // update global notification UI
                renderFailedNotifications();
                console.error('Save failed for player after retries, persisted for later', index);
                return { success: false };
            }

            await attemptSaveWithRetries();
        }

        // helper to save grid
        async function saveGrid(gridArray) {
            try {
                const resp = await $.ajax({
                    url: '?handler=SaveGrid',
                    method: 'POST',
                    contentType: 'application/json',
                    headers: {
                        'RequestVerificationToken': antiforgeryToken
                    },
                    data: JSON.stringify({ grid: gridArray })
                });
                if (!resp || !resp.success) return { success: false, error: resp && resp.error ? resp.error : 'unknown' };
                return { success: true };
            } catch (e) {
                return { success: false, error: e && e.message ? e.message : String(e) };
            }
        }

        // Document ready - initialize jQuery elements and event handlers
        $(function() {
            // Initialize jQuery elements
            $playerCountSelect = $('#playerCount');
            $playersContainer = $('#playersContainer');
            $shuffleBtn = $('#shuffleBtn');
            $reviewLink = $('#reviewLink');

            // Disable Review link initially
            $reviewLink.addClass('disabled');

            // Shuffle button behavior: populate grid, save it, and enable player1 start
            $shuffleBtn.on('click', async () => {
                shuffleGrid();

                // build grid array (flattened row-major)
                const grid = [];
                for (let r = 1; r <= rows; r++) {
                    for (let c = 1; c <= cols; c++) {
                        const id = `r${r}c${c}`;
                        const $el = $(`#${id}`);
                        grid.push($el.length > 0 && $el.text() ? $el.text().trim() : '');
                    }
                }

                // try to save grid with retries; if final failure, persist locally but allow play to continue
                let gridSaved = false;
                for (let attempt = 1; attempt <= MAX_SAVE_RETRIES; attempt++) {
                    const res = await saveGrid(grid);
                    if (res.success) { gridSaved = true; break; }
                    const delay = Math.min(BASE_BACKOFF_MS * Math.pow(2, attempt - 1), MAX_BACKOFF_MS);
                    await new Promise(r => setTimeout(r, delay));
                }
                if (!gridSaved) {
                    const rec = { id: `${Date.now()}-${Math.random().toString(36).slice(2)}`, grid: grid, error: 'max retries exceeded', ts: Date.now() };
                    addFailedGrid(rec);
                }

                // reset hidden words
                for (let i = 0; i < playerHiddenWords.length; i++) playerHiddenWords[i] = [];
                // reset displays
                renderPlayers(parseInt($playerCountSelect.val()));
                // enable first player's start
                enableStart(0);
                $shuffleBtn.prop('disabled', true);
            });

            // Player count change handler
            $playerCountSelect.on('change', () => {
                renderPlayers(parseInt($playerCountSelect.val()));
                updateReviewLinkState();
            });

            // Initial render
            renderPlayers(parseInt($playerCountSelect.val()));
            updateReviewLinkState();

            // attempt to resend failed saves and grids on load and when network returns
            tryResendFailedSaves();
            tryResendFailedGrids();
            $(window).on('online', () => { tryResendFailedSaves(); tryResendFailedGrids(); });

            // Instructions modal functionality
            const $modal = $('#instructionsModal');
            const $instructionsLink = $('#instructionsLink');
            const $closeBtn = $('.close');

            $instructionsLink.on('click', (e) => {
                e.preventDefault();
                $modal.show();
            });

            $closeBtn.on('click', () => {
                $modal.hide();
            });

            $(window).on('click', (e) => {
                if (e.target.id === 'instructionsModal') {
                    $modal.hide();
                }
            });
        });
    </script>
</div>
